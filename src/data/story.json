      "slug": "letter",
      "sections": [
        {
          "title": "Your Letter",
          "blocks": [
            {
              "type": "paragraph",
              "text": "Hi Love,"
            },
            {
              "type": "paragraph",
              "text": "Some gifts fade. Flowers wilt. Chocolates disappear. Even photographs become old."
            },
            {
              "type": "paragraph",
              "text": "But I wanted to give you something that would always be waiting whenever you looked up."
            },
            {
              "type": "paragraph",
              "text": "So today, I dedicate the brightest light in the heart of Leo to you."
            },
            {
              "type": "paragraph",
              "text": "Every time we find this star together, I hope it reminds you that no matter where life takes us, my heart will always find its way back to yours."
            },
            {
              "type": "paragraph",
              "text": "Happy Birthday."
            },
            {
              "type": "signature",
              "text": "❤️ Harshit"
            }
          ]
        }
      ]
    },
